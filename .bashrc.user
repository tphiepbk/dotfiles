#!/bin/bash

########################################################################
# AUTHOR: Hiep Phuc Thai                                               #
# It takes me 2 years to finish this shiet, but it's worth every penny #
# It's not just about the implementation, it's about the idea also     #
########################################################################

# RULES
# - Use the keyword "function" before function
# - Use the underline "_" before function name to hide it from bash completion

# ========================================================== DEFAULT EXPORT =====================================================================

export LESS="-XRI"
export EDITOR=vim

# tmux tmp dir
export TMUX_TMPDIR="$HOME/.tmux"

# cargo
# shellcheck source="/dev/null"
source "$HOME/.cargo/env"

# my common scripts
if [[ ! "$PATH" == *"$HOME/.scripts"* ]]; then
    export PATH="$HOME/.scripts:$PATH"
fi

# nodejs
export NVM_DIR="$HOME/.nvm"
# shellcheck source=/dev/null
[ -s "$NVM_DIR/nvm.sh" ] && \. "${NVM_DIR}/nvm.sh"  # This loads nvm
# shellcheck source=/dev/null
[ -s "$NVM_DIR/bash_completion" ] && \. "${NVM_DIR}/bash_completion"  # This loads nvm bash_completion

# ========================================================== DEFAULT OPTIONS =====================================================================

_EZA_COMMON_OPTS=("--long" "--classify=always" "--color=always" "--icons=always" "--all" "--all" "--binary" "--group" "--mounts" "--modified")

# This will fix issue when FZF preview does not recognize time style option format
_EZA_LIST_OPTS=("${_EZA_COMMON_OPTS[@]}" "--time-style=+%a %d-%m-%Y %H:%M:%S")
_EZA_FZF_OPTS=("${_EZA_COMMON_OPTS[@]}" "--time-style=+%a\ %d-%m-%Y\ %H:%M:%S")

_BAT_OPTS=("--color=always")

_FZF_DEFAULT_OPTS=("--reverse" "--border" "--height='70%'" "--preview-window '45%,~3'")
export FZF_DEFAULT_OPTS="${_FZF_DEFAULT_OPTS[*]}"

_FZF_TMUX_OPTS=("-p 90%,70%")

# ========================================================== PROMPT UTILITIES =====================================================================

# PROMPT CUSTOMIZATION
PROMPT_COMMAND=_prompt_command

DIRECTORY_HISTORY_FILE="$HOME/.directory_history"
MAX_LINE_DIRECTORY_HISTORY=100

# Utility to store the current visited directory
# If directory is already exists, we will not save it
function _store_current_directory () {
    if [[ ! -e "${DIRECTORY_HISTORY_FILE}" ]]; then
        touch "${DIRECTORY_HISTORY_FILE}"
    fi
    local current_dir
    current_dir="$(pwd)"
    if ! grep -q "${current_dir}" "${DIRECTORY_HISTORY_FILE}"; then
        echo "${current_dir}" >> "${DIRECTORY_HISTORY_FILE}"
    fi
}

# Utility to removed the deleted directory which is still in the
# .directory_history file
function _remove_non_existent_directory() {
    while IFS= read -r dir; do
        if [[ ! -d $dir ]]; then
            # Use "|" instead because "/" will appear in the the "dir" variable
            # Could not use "/<text to delete>/d" also
            sed -i "s|$dir||" "${DIRECTORY_HISTORY_FILE}"
        fi
    done <<< "$(cat "${DIRECTORY_HISTORY_FILE}")"
    # Remove blank line
    sed -i '/^$/d' "${DIRECTORY_HISTORY_FILE}"
}

# Utility to clear the .directory_history file if it's too long
function _clear_directory_history() {
    local number_of_line
    number_of_line=$(wc -l "${DIRECTORY_HISTORY_FILE}" | cut -d" " -f1)
    if [[ "${number_of_line}" -gt "${MAX_LINE_DIRECTORY_HISTORY}" ]]; then
        echo "" > "${DIRECTORY_HISTORY_FILE}"
    fi
}

function _prompt_command () {
    local EXIT="$?"

    _remove_non_existent_directory

    _clear_directory_history

    _store_current_directory

    # Redundant line before prompt
    echo

    if ((COLUMNS < 130)); then
        _generate_prompt_lite $EXIT
        _FZF_FOLDER_OPTS=()
        _FZF_FILE_OPTS=("--multi")
    else
        _generate_prompt $EXIT
        _FZF_FOLDER_OPTS=("--preview" "eza ${_EZA_FZF_OPTS[*]} {}")
        _FZF_FILE_OPTS=("--multi" "--preview" "bat ${_BAT_OPTS[*]} {}")
    fi
}

function _parse_git_branch() {
    local git_branch
    git_branch=$(git branch 2> /dev/null | sed -e '/^[^*]/d' -e 's/* \(.*\)/\1/')
    if [[ -n "${git_branch}" ]]; then
        if [[ ! "${git_branch}" =~ ^\(.*\)$ ]]; then
            git_branch="(${git_branch})"
        fi
        echo "${git_branch}"
    fi
}

function _generate_prompt_lite() {
    local EXIT="$1"

    # Colors used in prompt
    local END_COLOR=
    END_COLOR=$(tput sgr0)

    local PURPLE=
    PURPLE=$(tput setaf 141)

    local VIOLET=
    VIOLET=$(tput setaf 177)

    local ORANGE=
    ORANGE=$(tput setaf 202)

    local DARKSLATEGRAY1=
    DARKSLATEGRAY1=$(tput setaf 81)

    local MAGENTA=
    MAGENTA=$(tput setaf 200)

    local RED=
    RED=$(tput setaf 196)

    local GREEN=
    GREEN=$(tput setaf 46)

    local BLUE=
    BLUE=$(tput setaf 39)

    local GOLD=
    GOLD=$(tput setaf 222)

    # Special colors
    local PS_RED=
    PS_RED="\[${RED}\]"

    local PS_GREEN=
    PS_GREEN="\[${GREEN}\]"

    local PS_GOLD=
    PS_GOLD="\[${GOLD}\]"

    local PS_VIOLET=
    PS_VIOLET="\[${VIOLET}\]"

    local PS_ORANGE=
    PS_ORANGE="\[${ORANGE}\]"

    local PS_DARKSLATEGRAY1=
    PS_DARKSLATEGRAY1="\[${DARKSLATEGRAY1}\]"

    local PS_MAGENTA=
    PS_MAGENTA="\[${MAGENTA}\]"

    local PS_BLUE=
    PS_BLUE="\[${BLUE}\]"

    local PS_END_COLOR=
    PS_END_COLOR="\[${END_COLOR}\]"

    # Define icons
    # Unicode character broken after sourcing openstack_vmware.sh
    # because that file have this command :export LC_ALL="C"
    # We should unset LC_ALL after sourcing that file
    local folder_icon=
    folder_icon=$'\uf07c'

    local git_icon=
    git_icon=$'\uf126'

    local jet_fighter_icon
    jet_fighter_icon=$'\uf0fb'

    local opendir_icon
    opendir_icon=$'\u276e'

    local closedir_icon
    closedir_icon=$'\u276f'

    local space
    space=" "

    # DEFINE PATTERNS

    # Configure the vi-ins/cmd-mode-string here instead of .inputrc
    local server_icon
    server_icon=$'\uf233'

    local pen_to_square_icon
    pen_to_square_icon=$'\uf044'

    local code_icon
    code_icon=$'\uf121'

    local vi_ins_mode_string="\1\e[34;1m\2(INS)${space}${pen_to_square_icon}${space}${space}\1\e[0m\2"
    local vi_cmd_mode_string="\1\e[33;1m\2(CMD)${space}${code_icon}${space}${space}\1\e[0m\2"

    bind "set vi-ins-mode-string \"${vi_ins_mode_string}\""
    bind "set vi-cmd-mode-string \"${vi_cmd_mode_string}\""

    # Username hostname part
    local current_username=
    current_username=$(whoami)
    local current_hostname=
    current_hostname=$(hostname)
    local username_hostname_part="${PS_VIOLET}${current_username}${PS_END_COLOR}${PS_RED}${jet_fighter_icon}${PS_END_COLOR}${space}${PS_VIOLET}${current_hostname}${PS_END_COLOR}"

    # Directory part
    local current_directory=
    current_directory=$(pwd)
    local current_directory_reduced=
    current_directory_reduced=$(pwd | rev | cut -d'/' -f1 | rev)
    local directory_part=
    directory_part="${PS_ORANGE}${folder_icon}${space}${space}${PS_END_COLOR}"
    directory_part+="${PS_RED}${opendir_icon}${PS_END_COLOR}"
    directory_part+="${PS_DARKSLATEGRAY1}${current_directory_reduced}${PS_END_COLOR}"
    directory_part+="${PS_RED}${closedir_icon}${PS_END_COLOR}"

    # Git branch part
    local current_git_branch=
    current_git_branch=$(_parse_git_branch)
    local current_git_branch_length=${#current_git_branch}
    local git_branch_part=
    if [[ $current_git_branch_length -ne 0 ]]; then
        git_branch_part="${git_icon}${space}${PS_ORANGE}${current_git_branch}${PS_END_COLOR}${space}"
    else
        git_branch_part=""
    fi

    # Python virtualenv part
    local python_venv_part
    local python_venv_part_length
    if [[ "${VIRTUAL_ENV_PROMPT}" ]]; then
        python_venv_part="${PS_BLUE}(${VIRTUAL_ENV_PROMPT})${PS_END_COLOR}${space}"
    else
        python_venv_part=""
    fi

    local zero_return_code_part="${PS_GREEN}(${EXIT})${PS_END_COLOR}"
    local non_zero_return_code_part="${PS_RED}(${EXIT})${PS_END_COLOR}"

    # Indicate if user it root (#) or otherwise ($)
    local user_type_indicator="${PS_MAGENTA}\$${PS_END_COLOR}"

    # Input indicator part
    local keyboard_icon=
    keyboard_icon=$'\uf11c'
    local input_indicator="${PS_GOLD}${keyboard_icon}${PS_END_COLOR}"

    # START MAKING PROMPT
    local generated_ps1="${username_hostname_part}${space}${directory_part}${space}${git_branch_part}${python_venv_part}"

    # Left part

    if [[ "$EXIT" -eq 0 ]]; then
        generated_ps1+="${zero_return_code_part}"
    else
        generated_ps1+="${non_zero_return_code_part}"
    fi

    generated_ps1+="${space}${user_type_indicator}${space}"
    generated_ps1+="${input_indicator}${space}${space}"

    PS1="${generated_ps1}"
}

function _generate_prompt() {
    local EXIT="$1"

    # Colors used in prompt
    local END_COLOR=
    END_COLOR="$(tput sgr0)"

    local PURPLE=
    PURPLE=$(tput setaf 141)

    local VIOLET=
    VIOLET=$(tput setaf 177)

    local ORANGE=
    ORANGE="$(tput setaf 202)"

    local MAGENTA=
    MAGENTA=$(tput setaf 200)

    local YELLOW=
    YELLOW=$(tput setaf 11)

    local DARKSLATEGRAY1=
    DARKSLATEGRAY1=$(tput setaf 123)

    local RED=
    RED=$(tput setaf 196)

    local GREEN=
    GREEN=$(tput setaf 46)

    local BLUE=
    BLUE=$(tput setaf 39)

    local GOLD=
    GOLD=$(tput setaf 222)

    # Special colors
    local PS_RED=
    PS_RED="\[${RED}\]"

    local PS_GREEN=
    PS_GREEN="\[${GREEN}\]"

    local PS_GOLD=
    PS_GOLD="\[${GOLD}\]"

    local PS_END_COLOR=
    PS_END_COLOR="\[${END_COLOR}\]"

    # Define icons
    # Unicode character broken after sourcing openstack_vmware.sh
    # because that file have this command :export LC_ALL="C"
    # We should unset LC_ALL after sourcing that file
    local jet_fighter_icon
    jet_fighter_icon=$'\uf0fb'

    local calendar_icon=
    calendar_icon=$'\uf133'

    local clock_icon=
    clock_icon=$'\uf017'

    local folder_icon=
    folder_icon=$'\uf07c'

    local git_icon=
    git_icon=$'\uf126'

    local check_icon
    check_icon=$'\uf058'

    local cross_icon=
    cross_icon=$'\uf057'

    local linux_penguin_icon
    linux_penguin_icon=$'\uf17c'

    local dash_icon
    dash_icon=$'\u23af'

    local internal_dot_icon
    internal_dot_icon=$'\u25ce'

    local first_line_start_icon
    first_line_start_icon=$'\u256d'

    local second_line_start_icon
    second_line_start_icon=$'\u2570'

    local datetime_open_icon
    datetime_open_icon=$'\uf0d9'

    local datetime_close_icon
    datetime_close_icon=$'\uf0da'

    local opendir_icon
    opendir_icon=$'\u276e'

    local closedir_icon
    closedir_icon=$'\u276f'

    local space
    space=" "

    local space_length=1
    local icon_length=1
    local punctuation_length=1

    # Configure the vi-ins/cmd-mode-string here instead of .inputrc
    local server_icon
    server_icon=$'\uf233'

    local pen_to_square_icon
    pen_to_square_icon=$'\uf044'

    local code_icon
    code_icon=$'\uf121'

    local second_line_left_symbol="\1\e[1;33m\2${second_line_start_icon}${dash_icon}${internal_dot_icon}\1\e[0m\2${space}"
    second_line_left_symbol+="\1\e[32;1m\2${server_icon}${space}\1\e[0m\2"
    local vi_ins_mode_string="${second_line_left_symbol}${space}\1\e[34;1m\2(INS)${space}${pen_to_square_icon}${space}\1\e[0m\2"
    local vi_cmd_mode_string="${second_line_left_symbol}${space}\1\e[33;1m\2(CMD)${space}${code_icon}${space}\1\e[0m\2"

    bind "set vi-ins-mode-string \"${vi_ins_mode_string}\""
    bind "set vi-cmd-mode-string \"${vi_cmd_mode_string}\""

    # Define patterns
    local first_line_left_symbol="${YELLOW}${first_line_start_icon}${dash_icon}${internal_dot_icon}${END_COLOR}${ORANGE}${space}${linux_penguin_icon}${END_COLOR}${space}"
    local first_line_left_symbol_length=$((icon_length * 3 + space_length + icon_length + space_length))

    # Datetime icon
    local datetime_symbol_length=5
    local first_line_datetime_left_symbol="${MAGENTA}"
    local first_line_datetime_right_symbol="${MAGENTA}"
    for ((i = 0 ; i < datetime_symbol_length ; i++)); do
      first_line_datetime_left_symbol+="${datetime_open_icon}"
      first_line_datetime_right_symbol+="${datetime_close_icon}"
    done
    first_line_datetime_left_symbol+="${END_COLOR}"
    first_line_datetime_right_symbol+="${END_COLOR}"

    # Datetime part
    local datetime_part
    local datetime_part_length

    datetime_part="${first_line_datetime_left_symbol}"
    datetime_part_length="${datetime_symbol_length}"

    datetime_part+="${space}"
    ((datetime_part_length += space_length))

    local current_date
    current_date=$(date +"%d/%m/%Y")
    datetime_part+="${GREEN}${calendar_icon}${space}${END_COLOR}${PURPLE}${current_date}${END_COLOR}"
    ((datetime_part_length += icon_length))
    ((datetime_part_length += space_length))
    ((datetime_part_length += ${#current_date}))

    datetime_part+="${space}"
    ((datetime_part_length += space_length))

    local current_time
    current_time=$(date +"%H:%M:%S")
    datetime_part+="${GREEN}${clock_icon}${space}${PURPLE}${current_time}${END_COLOR}"
    ((datetime_part_length += icon_length))
    ((datetime_part_length += space_length))
    ((datetime_part_length += ${#current_time}))

    datetime_part+="${space}"
    ((datetime_part_length += space_length))

    datetime_part+="${first_line_datetime_right_symbol}"
    ((datetime_part_length += datetime_symbol_length))

    # Username hostname part
    local current_username=
    current_username=$(whoami)
    local current_username_length=${#current_username}
    local current_hostname=
    current_hostname=$(hostname)
    local current_hostname_length=${#current_hostname}
    local username_hostname_part="${VIOLET}${current_username}${END_COLOR}${RED}${jet_fighter_icon}${space}${END_COLOR}${VIOLET}${current_hostname}${END_COLOR}"
    local username_hostname_part_length=$((current_username_length + icon_length + space_length + current_hostname_length))

    # Git branch part
    local current_git_branch=
    current_git_branch=$(_parse_git_branch)
    local current_git_branch_length=${#current_git_branch}
    local git_branch_part=
    local git_branch_part_length=
    if [[ $current_git_branch_length -ne 0 ]]; then
        git_branch_part="${git_icon}${space}${ORANGE}${current_git_branch}${END_COLOR}${space}"
        git_branch_part_length=$((icon_length + space_length + current_git_branch_length + space_length))
    else
        git_branch_part=""
        git_branch_part_length=0
    fi

    # Directory part
    local current_full_directory
    current_full_directory=$(pwd)
    local current_full_directory_length=${#current_full_directory}
    local current_directory
    local current_directory_length
    if ((current_full_directory_length + current_git_branch_length >= COLUMNS * 60 / 100)); then
      current_directory=$(pwd | rev | cut -d'/' -f1 | rev)
    else
      current_directory=${current_full_directory}
    fi
    current_directory_length=${#current_directory}

    local directory_part
    local directory_part_length

    directory_part="${ORANGE}${folder_icon}${space}${space}${END_COLOR}"
    directory_part_length=$((icon_length + space_length * 2))

    directory_part+="${RED}${opendir_icon}${END_COLOR}"
    ((directory_part_length += icon_length))

    directory_part+="${DARKSLATEGRAY1}${current_directory}${END_COLOR}"
    ((directory_part_length += current_directory_length))

    directory_part+="${RED}${closedir_icon}${END_COLOR}"
    ((directory_part_length += icon_length))

    # Python virtualenv part
    local python_venv_part
    local python_venv_part_length
    if [[ "${VIRTUAL_ENV_PROMPT}" ]]; then
        python_venv_part="${BLUE}(${VIRTUAL_ENV_PROMPT})${END_COLOR}${space}"
        python_venv_part_length=$(( ${#VIRTUAL_ENV_PROMPT} + punctuation_length * 2 + space_length ))
    else
        python_venv_part=""
        python_venv_part_length=0
    fi

    # Return code part
    local zero_return_code_part="${PS_GREEN}${EXIT}${space}${check_icon}${PS_END_COLOR}"
    local non_zero_return_code_part="${PS_RED}${EXIT}${space}${cross_icon}${PS_END_COLOR}"

    # Input indicator part
    local keyboard_icon=
    keyboard_icon=$'\uf11c'
    local play_icon=
    play_icon=$'\uf04b'
    local input_indicator=
    input_indicator="${PS_GOLD}${play_icon}${play_icon}${play_icon}${play_icon}${space}${keyboard_icon}${PS_END_COLOR}"

    # START MAKING PROMPT
    local PS1_first_line=""
    local PS1_second_line=""

    # Left part
    local PS1_first_line_left_part
    local PS1_first_line_left_part_length

    PS1_first_line_left_part="${first_line_left_symbol}${space}"
    PS1_first_line_left_part_length=$((first_line_left_symbol_length + space_length))

    PS1_first_line_left_part+="${username_hostname_part}${space}"
    ((PS1_first_line_left_part_length+=(username_hostname_part_length + space_length)))

    PS1_first_line_left_part+="${directory_part}${space}"
    ((PS1_first_line_left_part_length+=(directory_part_length + space_length)))

    PS1_first_line_left_part+="${git_branch_part}"
    ((PS1_first_line_left_part_length+=(git_branch_part_length)))

    PS1_first_line_left_part+="${MAGENTA}\$${END_COLOR}${space}"
    ((PS1_first_line_left_part_length+=(icon_length + space_length)))

    # Right part
    local PS1_first_line_right_part
    PS1_first_line_right_part="${space}${python_venv_part}${datetime_part}"
    local PS1_first_line_right_part_length
    PS1_first_line_right_part_length=$((space_length + python_venv_part_length + datetime_part_length))

    # Calculate number of available space
    local number_of_available_space=$((COLUMNS-PS1_first_line_left_part_length-PS1_first_line_right_part_length))

    # Middle part
    local PS1_first_line_middle_part="${YELLOW}${internal_dot_icon}"
    ((number_of_available_space-=2))
    for ((i = 0 ; i < number_of_available_space ; i++)); do
        PS1_first_line_middle_part+="${dash_icon}"
    done
    PS1_first_line_middle_part+="${internal_dot_icon}${END_COLOR}"

    # Combination
    PS1_first_line+="${PS1_first_line_left_part}"
    PS1_first_line+="${PS1_first_line_middle_part}"
    PS1_first_line+="${PS1_first_line_right_part}"

    PS1_second_line+="${space}"

    if [[ "$EXIT" -eq 0 ]]; then
        PS1_second_line+="${zero_return_code_part}"
    else
        PS1_second_line+="${non_zero_return_code_part}"
    fi

    PS1_second_line+="  ${input_indicator}  "

    echo -e "${PS1_first_line}"

    PS1="${PS1_second_line}"
}

# ========================================================== LISTING UTILITIES =====================================================================

# My custom list directory command
# Only use "less" when there are more than 30 directory appears
function _my_ll_command() {
    NUMBER_OF_LINE=$(find "$@" -maxdepth 1 | wc -l)
    if ((NUMBER_OF_LINE > LINES)); then
        eza "${_EZA_LIST_OPTS[@]}" "$@" | less
    else
        eza "${_EZA_LIST_OPTS[@]}" "$@"
    fi
    return $?
}

function _my_tree_command() {
    local CURRENT_DIRECTORY=
    if [[ -z "$1" ]]; then
        CURRENT_DIRECTORY="."
    else
        CURRENT_DIRECTORY="$1"
    fi

    if [[ -e "${CURRENT_DIRECTORY}" ]]; then
        NUMBER_OF_LINE=$(tre --all "${CURRENT_DIRECTORY}" | wc -l)
        if [[ "${NUMBER_OF_LINE}" -gt "$LINES" ]]; then
            tre --all --color always "${CURRENT_DIRECTORY}" | less
        else
            tre --all --color always "${CURRENT_DIRECTORY}"
        fi
        return $?
    else
        echo "tre: cannot access '$1': No such file or directory"
        return 2
    fi
}

# ========================================================== FZF UTILITIES =====================================================================

function _show_history_using_fzf () {
    local HISTORY_FZF_RESULTS=
    HISTORY_FZF_RESULTS="$(history | fzf-tmux "${_FZF_TMUX_OPTS[@]}" --tac --tiebreak=index | cut -d " " -f 4-)"

    # Original behavior: parse the output of fzf command after the current content in prompt
    # READLINE_LINE=${READLINE_LINE:+${READLINE_LINE:0:READLINE_POINT}}${INPUT}${READLINE_LINE:+${READLINE_LINE:READLINE_POINT}}
    # READLINE_POINT=$(( READLINE_POINT + ${#INPUT} ))
    # Clear all the content in prompt before parsing the output of fzf command
    READLINE_LINE=${HISTORY_FZF_RESULTS}
    READLINE_POINT=${#HISTORY_FZF_RESULTS}
}

# Mapping Ctrl-R with fzf
bind -x '"\C-r": _show_history_using_fzf';

function _call_tool_with_fzf_utility () {
    local tool="$1"
    shift
    local options="$*"
    local fzf_output
    fzf_output=$(find . -type f -printf "%P\\n"| fzf-tmux "${_FZF_TMUX_OPTS[@]}" "${_FZF_FILE_OPTS[@]}")
    local ret_code="$?"
    if [[ -n ${fzf_output} && "${ret_code}" -eq 0 ]]; then
        if [[ -n "$options" ]]; then
            "$tool" "$options" "${fzf_output}"
        else
            "$tool" "${fzf_output}"
        fi
        ret_code="$?"
    fi
    return "${ret_code}"
}

function _cd_fzf_utility () {
    local fzf_output
    local git_branch
    git_branch=$(_parse_git_branch)
    if [[ -n ${git_branch} ]]; then
        local git_root_dir
        git_root_dir=$(git rev-parse --show-toplevel)
        fzf_output=$( (cat "${DIRECTORY_HISTORY_FILE}" && find . "${git_root_dir}" -mindepth 1 -type d -printf "%P\\n") | fzf-tmux "${_FZF_TMUX_OPTS[@]}" "${_FZF_FOLDER_OPTS[@]}" )
    else
        fzf_output=$( (cat "${DIRECTORY_HISTORY_FILE}" && find . -mindepth 1 -type d -printf "%P\\n") | fzf-tmux "${_FZF_TMUX_OPTS[@]}" "${_FZF_FOLDER_OPTS[@]}" )
    fi
    if [[ -n ${fzf_output} ]]; then
       cd "${fzf_output}" || return 1
    fi
}

# ========================================================== TMUX UTILITIES =====================================================================

# Utility to call tmux whenever start
function _start_tmux_utility () {
    local TMUX_INIT_SESSION="${USER}"
    local TMUX_INIT_WINDOW="misc"

    local TMUX_DEFAULT_FILE="/tmp/tmux-2645/default"

    # If we are currently not in tmux, start tmux
    # if not, do nothing
    if [[ -z "$TMUX" ]]; then
        # Check if tmux file exists
        if [[ ! -e "$TMUX_DEFAULT_FILE" ]]; then
            echo "Trying restoring tmux..."
            pkill -USR1 tmux
        fi

        # Check if tmux works fine
        # or if there is not any tmux session
        if ! tmux ls; then
            echo "Something went wrong after restoring, creating new session..."
            if ! tmux new -s "$TMUX_INIT_SESSION" -n "$TMUX_INIT_WINDOW"; then
                echo "$TMUX_INIT_SESSION already exists, entering..."
                tmux a -t "$TMUX_INIT_SESSION"
            fi
        else
            echo "Entering first session of the list"
            local first_session=
            first_session=$(tmux ls | head -n 1 | cut -d ":" -f1)
            tmux a -t "$first_session"
        fi
    else
        # Already in TMUX
        echo "Already in tmux, skipping..."
    fi
}

# ========================================================== BACKUP RESTORE UTILITIES =====================================================================

# Utility to backup all necessary configuration files
function _backup_utility () {
    local ARGS=("$@")

    local BACKUP_DIRECTORY="${ARGS[0]}"
    local NUMBER_OF_DIRECTORIES="${ARGS[1]}"

    local BACKUP_LIST=("${ARGS[@]:2:$NUMBER_OF_DIRECTORIES}")
    local RESTORE_LIST=("${ARGS[@]:(( 2 + NUMBER_OF_DIRECTORIES )):$NUMBER_OF_DIRECTORIES}")

    local RETCODE=

    echo "[STAGE] Backing up all configuration files..."

    # Checking the directory to store backup
    if [[ ! -d $BACKUP_DIRECTORY ]]; then
        echo "Creating backup directory..."
        mkdir -p "$HOME"/.backup
    fi

    # Backing up all needed files
    for (( i = 0 ; i < NUMBER_OF_DIRECTORIES ; i++ )); do
        local to_backup_dir="${BACKUP_LIST[i]}"
        local to_restore_dir="${RESTORE_LIST[i]}"

        echo "Checking directory: $HOME/$to_backup_dir"
        if [[ ! -e "$HOME/$to_backup_dir" ]]; then
            echo "$HOME/$to_backup_dir not exists. Skip !"
            RETCODE=4
        else
            # Handle separately for folders and files
            if [[ -d "$HOME/$to_backup_dir" ]]; then
                if tar -C "$HOME/" -czf "$BACKUP_DIRECTORY/$to_restore_dir" "$to_backup_dir"; then
                    echo "Backup $to_backup_dir successfully"
                    RETCODE=0
                else
                    echo "Failed to backup $to_backup_dir. Skip !"
                    RETCODE=4
                fi
            else
                # \cp to force overwrite when copying
                if \cp -rf "$HOME/$to_backup_dir" "${BACKUP_DIRECTORY}/$to_restore_dir"; then
                    echo "Backup $to_backup_dir successfully"
                    RETCODE=0
                else
                    echo "Failed to backup $to_backup_dir. Skip !"
                    RETCODE=4
                fi
            fi

        fi
    done

    return $RETCODE
}

# Utility to restore all necessary configuration files and folders
function _restore_utility () {
    local ARGS=("$@")

    local BACKUP_DIRECTORY="${ARGS[0]}"
    local NUMBER_OF_DIRECTORIES="${ARGS[1]}"

    local BACKUP_LIST=("${ARGS[@]:2:$NUMBER_OF_DIRECTORIES}")
    local RESTORE_LIST=("${ARGS[@]:(( 2 + NUMBER_OF_DIRECTORIES )):$NUMBER_OF_DIRECTORIES}")

    local RETCODE=

    echo "[STAGE] Restoring all configuration files..."

    # Checking the directory to store backup
    if [[ ! -d $BACKUP_DIRECTORY ]]; then
        echo "Backup directory not found"
        RETCODE=3
    fi

    for (( i = 0 ; i < NUMBER_OF_DIRECTORIES ; i++ )); do
    # Restoring all needed files
        local to_backup_dir="${BACKUP_LIST[i]}"
        local to_restore_dir="${RESTORE_LIST[i]}"

        echo "Checking directory: $BACKUP_DIRECTORY/$to_restore_dir"
        if [[ ! -e "$BACKUP_DIRECTORY/$to_restore_dir" ]]; then
            echo "$BACKUP_DIRECTORY/$to_restore_dir not exists. Skip !"
            RETCODE=4
        else
            # Handle separately for folders and files
            if [[ "$to_restore_dir" =~ .tar.gz$ ]]; then
                if rm -rf "${HOME}/${to_backup_dir:?}"; then
                    if tar -xzf "$BACKUP_DIRECTORY/$to_restore_dir" -C "${HOME}"; then
                        echo "Restore $to_backup_dir successfully"
                        RETCODE=0
                    else
                        echo "Failed to restore $to_backup_dir. Skip !"
                        RETCODE=4
                    fi
                else
                    echo "Failed to remove old configuration files. Skip !"
                    RETCODE=6
                fi
            else
                # \cp to force overwrite when copying
                if \cp -rf "${BACKUP_DIRECTORY}/$to_restore_dir" "$HOME/$to_backup_dir"; then
                    echo "Restore $to_backup_dir successfully"
                    RETCODE=0
                else
                    echo "Failed to restore $to_backup_dir. Skip !"
                    RETCODE=4
                fi
            fi
        fi
    done

    # Apply the restored configuration
    echo -e "\nReloading all configuration files..."
    local source_command=""
    for (( i = 0 ; i < NUMBER_OF_DIRECTORIES ; i++ )); do
        local to_backup_dir="${BACKUP_LIST[i]}"
        local to_restore_dir="${RESTORE_LIST[i]}"
        # Do not reload folder and .gitconfig file
        if [[ ! "$to_restore_dir" =~ .tar.gz$ ]]; then
            if [[ "$to_backup_dir" != ".gitconfig" ]]; then
                echo "Reloading file: $HOME/$to_backup_dir"

                if [[ $to_backup_dir == ".tmux.conf" ]]; then
                    if tmux ls; then
                        source_command="tmux source-file $HOME/$to_backup_dir"
                    else
                        source_command=""
                    fi
                else
                    source_command="source $HOME/$to_backup_dir"
                fi

                if [[ -n "$source_command" ]]; then
                    if $source_command; then
                        echo "Reloaded file: $HOME/$to_backup_dir successfully"
                        RETCODE=0
                    else
                        RETCODE=5
                    fi
                else
                    echo "Skip reloading file: $HOME/$to_backup_dir"
                fi
            fi
        fi
    done

    return $RETCODE
}

# BRF command
function _my_brf_command () {
    local ACTION="$1"
    local BACKUP_DIRECTORY="$HOME/.backup"
    local BACKUP_LIST=( ".bashrc.user"  ".inputrc"  ".gitconfig"    ".config/nvim"          ".tmux/scripts"         ".tmux.conf"    ".ssh")
    local RESTORE_LIST=("bashrc.user"   "inputrc"   "gitconfig"     "config_nvim.tar.gz"    "tmux_scripts.tar.gz"   "tmux.conf"     "ssh.tar.gz")

    local NUMBER_OF_DIRECTORIES=${#BACKUP_LIST[@]}

    local RETCODE=

    # Unalias cp command
    if alias cp > /dev/null 2>&1; then
        unalias cp
    fi

    if [[ -z $ACTION ]]; then
        echo "No action is defined"
        RETCODE=1
    else
        if [[ $ACTION == "backup" ]]; then
            _backup_utility "$BACKUP_DIRECTORY" "$NUMBER_OF_DIRECTORIES" "${BACKUP_LIST[@]}" "${RESTORE_LIST[@]}"
            RETCODE=$?
            if [[ "$RETCODE" -eq 0 ]]; then
                echo "-----------------------------------"
                echo "[STAGE] Publishing the configurations"
                # TBD: added the online backup
            fi
        elif [[ $ACTION == "restore" ]]; then
            _restore_utility "$BACKUP_DIRECTORY" "$NUMBER_OF_DIRECTORIES" "${BACKUP_LIST[@]}" "${RESTORE_LIST[@]}"
            RETCODE=$?
        else
            echo "Wrong action"
            RETCODE=2
        fi
    fi

    # Re-alias cp command
    if ! alias cp > /dev/null 2>&1; then
        alias cp='cp -i'
    fi

    return $RETCODE
}

# ========================================================== ALIASES =====================================================================

# confiruration
alias bashconf="nvim \$HOME/.bashrc.user"
alias bashview="bat \$HOME/.bashrc.user"
alias bashreload="source \$HOME/.bashrc.user"
alias inputconf="nvim \$HOME/.inputrc"
alias inputview="bat \$HOME/.inputrc"
alias tmuxconf="nvim \$HOME/.tmux.conf"
alias tmuxview="bat \$HOME/.tmux.conf"
alias gitconf="nvim \$HOME/.gitconfig"
alias gitview="bat \$HOME/.gitconfig"
alias netrconf="nvim \$HOME/.netrc"
alias netrview="bat \$HOME/.netrc"

# working
alias ll="_my_ll_command"
alias l="_my_ll_command"
alias lt="_my_tree_command"
alias cls="clear"
alias nvimf="_call_tool_with_fzf_utility nvim"
alias vimf="_call_tool_with_fzf_utility vim"
alias batf="_call_tool_with_fzf_utility bat"
alias lessf="_call_tool_with_fzf_utility less"
alias catf="_call_tool_with_fzf_utility cat"
alias cdi="_cd_fzf_utility"
alias working='cd $HOME/workspace'
alias gitroot='cd "$(git root)"'
alias dt='delta --side-by-side --diff-args=-U999'
#alias gl='glow --tui --line-numbers --preserve-new-lines -w $COLUMNS'
alias gl='glow --pager --preserve-new-lines -w $COLUMNS'

# start tmux
alias tux="_start_tmux_utility"

# backup restore utility
alias brfconf="_my_brf_command"
complete -W "backup restore" brfconf

export VIRTUALENVWRAPPER_PYTHON=/usr/bin/python3
export VIRTUALENVWRAPPER_VIRTUALENV=/usr/local/bin/virtualenv
# shellcheck source=/dev/null
source /usr/local/bin/virtualenvwrapper.sh
